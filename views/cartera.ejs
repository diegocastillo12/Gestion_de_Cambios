<%- include('partials/head') %>

<div class="app-wrapper">
  <%- include('partials/sidebar') %>

  <main class="main-content">

    <div class="page-container">
      <!-- Hero -->
      <div class="cartera-hero" style="margin-bottom: 20px;">
        <h1>Mi Cartera de Proyectos</h1>
        <p>Bienvenido/a, <%= user.nombre %>. Aqui tienes todos tus proyectos asignados.</p>
      </div>

      <% if (proyectos && proyectos.length > 0) { %>
      <div class="proyectos-grid">
        <% proyectos.forEach(p => {
          const avance = parseFloat(p.promedio_avance || 0);
          const miAvance = p.mi_promedio_avance !== null ? parseFloat(p.mi_promedio_avance) : null;
          const estadoClass = 'estado-' + (p.estado || 'Activo').replace(/\s/g,'');
        %>
        <a href="/proyectos/<%= p.id_proyecto %>" class="proyecto-card">
          <div class="proyecto-card-header">
            <div>
              <div class="proyecto-card-title"><%= p.nombre %></div>
              <% if (p.github_repo) { %>
              <span class="badge badge-green" style="font-size:10px; margin-top:4px; display:inline-flex;">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                <%= p.github_repo %>
              </span>
              <% } %>
            </div>
            <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
              <span class="estado-badge <%= estadoClass %>"><%= p.estado %></span>
              <% if (p.reportes_nuevos > 0) { %>
              <span class="badge-notif"><%= p.reportes_nuevos %></span>
              <% } %>
            </div>
          </div>

          <p class="proyecto-card-desc"><%= p.descripcion || 'Sin descripcion.' %></p>

          <!-- Barra de avance del proyecto (global) -->
          <div class="progreso-label">
            <span>Avance global del proyecto</span>
            <strong><%= avance %>%</strong>
          </div>
          <div class="progress-bar-outer">
            <div class="progress-bar-inner" style="width:<%= avance %>%"></div>
          </div>

          <!-- Actividades asignadas a este usuario -->
          <% if (p.mis_actividades && p.mis_actividades.length > 0) { %>
          <div style="margin-top:10px; padding:8px 10px; background:var(--bg-accent); border-radius:var(--radius-sm); border:0.5px solid var(--border-accent);">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
              <span style="font-size:10px; font-weight:500; color:var(--text-accent); text-transform:uppercase; letter-spacing:0.06em;">Mis actividades (<%= p.mis_actividades.length %>)</span>
              <% if (miAvance !== null) { %>
              <span style="font-size:11px; font-weight:500; color:var(--text-accent);"><%= miAvance %>% mi avance</span>
              <% } %>
            </div>
            <% p.mis_actividades.slice(0, 3).forEach(a => {
              const aBadge = a.estado === 'Completado' ? 'var(--text-success)' : a.estado === 'En Progreso' ? 'var(--text-warning)' : 'var(--text-muted)';
            %>
            <div style="display:flex; align-items:center; gap:6px; margin-bottom:3px;">
              <span style="width:6px; height:6px; border-radius:50%; background:<%= aBadge %>; flex-shrink:0;"></span>
              <span style="font-size:11px; flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= a.nombre %></span>
              <span style="font-size:10px; font-weight:500; color:var(--text-accent);"><%= parseFloat(a.porcentaje_avance||0).toFixed(0) %>%</span>
            </div>
            <% }); %>
            <% if (p.mis_actividades.length > 3) { %>
            <div style="font-size:10px; color:var(--text-muted); margin-top:2px;">+ <%= p.mis_actividades.length - 3 %> mas</div>
            <% } %>
          </div>
          <% } %>

          <div class="proyecto-card-meta">
            <% if (p.fecha_inicio) { %>
            <span>
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <%= new Date(p.fecha_inicio).toLocaleDateString('es-PE') %>
            </span>
            <% } %>
            <% if (p.fecha_fin) { %>
            <span>
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <%= new Date(p.fecha_fin).toLocaleDateString('es-PE') %>
            </span>
            <% } %>
            <span>
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
              <%= p.total_actividades || 0 %> actividades
            </span>
            <% if (p.metodologia_nombre) { %>
            <span>
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
              <%= p.metodologia_nombre %>
            </span>
            <% } %>
          </div>
        </a>
        <% }); %>
      </div>

      <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto; display:block; opacity:0.35;"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h3 style="margin-bottom:6px; font-size:14px; font-weight:500;">Sin proyectos asignados</h3>
        <p>El administrador aun no te ha asignado a ningun proyecto.</p>
      </div>
      <% } %>

    </div>

  </main>
</div>

<%- include('partials/footer') %>
