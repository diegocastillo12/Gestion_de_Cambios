<%- include('partials/head') %>

<div class="app-wrapper">
  <%- include('partials/sidebar', { user, roles }) %>

  <div class="main-content">

    <!-- TOPBAR -->
    <header class="topbar">
      <button id="sidebar-toggle" class="btn btn-ghost btn-icon" aria-label="Abrir menú">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-left">
        <span class="topbar-title">Tickets de Cambio</span>
      </div>
      <div class="topbar-right">
        <% if ([roles.SOLICITANTE, roles.DIRECTOR_PROYECTO, roles.GESTOR_CONFIGURACION].includes(user.rol)) { %>
        <a href="/tickets/nuevo" class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nuevo Ticket
        </a>
        <% } %>
      </div>
    </header>

    <div class="page-container">

      <!-- FILTROS -->
      <form method="GET" action="/tickets" class="card mb-4" style="padding:12px 16px;">
        <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:flex-end;">
          <div style="flex:2; min-width:160px;">
            <label class="form-label" style="margin-bottom:4px; display:block;">Buscar</label>
            <input type="text" name="q" id="search-tickets"
              class="form-control" placeholder="ID, título o descripción..."
              value="<%= filtros.q || '' %>" style="margin:0;" />
          </div>
          <div style="flex:1; min-width:120px;">
            <label class="form-label" style="margin-bottom:4px; display:block;">Estado</label>
            <select name="estado" class="form-control" style="margin:0;">
              <option value="">Todos</option>
              <% estados.forEach(e => { %>
              <option value="<%= e %>" <%= filtros.estado === e ? 'selected' : '' %>><%= e %></option>
              <% }) %>
            </select>
          </div>
          <div style="flex:1; min-width:110px;">
            <label class="form-label" style="margin-bottom:4px; display:block;">Prioridad</label>
            <select name="prioridad" class="form-control" style="margin:0;">
              <option value="">Todas</option>
              <% prioridades.forEach(p => { %>
              <option value="<%= p %>" <%= filtros.prioridad === p ? 'selected' : '' %>><%= p %></option>
              <% }) %>
            </select>
          </div>
          <div style="flex:1; min-width:130px;">
            <label class="form-label" style="margin-bottom:4px; display:block;">Tipo</label>
            <select name="tipo" class="form-control" style="margin:0;">
              <option value="">Todos</option>
              <% tiposCambio.forEach(t => { %>
              <option value="<%= t %>" <%= filtros.tipo === t ? 'selected' : '' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div style="display:flex; gap:6px; align-self:flex-end;">
            <button type="submit" class="btn btn-primary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              Filtrar
            </button>
            <a href="/tickets" class="btn btn-secondary btn-sm">Limpiar</a>
          </div>
        </div>
      </form>

      <!-- TABLA DE TICKETS -->
      <div class="table-wrapper">
        <% if (tickets.length === 0) { %>
        <div style="text-align:center; padding:40px 20px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 12px; display:block; color:var(--text-muted); opacity:0.5;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <h3 style="color:var(--text-secondary); font-size:14px; margin-bottom:6px;">Sin resultados</h3>
          <p style="font-size:12px;">No se encontraron tickets con los filtros aplicados.</p>
          <a href="/tickets" class="btn btn-secondary btn-sm" style="margin-top:14px;">Limpiar filtros</a>
        </div>
        <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Titulo / Etiquetas</th>
              <th>Estado</th>
              <th>Prioridad</th>
              <th>Tipo</th>
              <th>Solicitante</th>
              <th>Actualizado</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% tickets.forEach(t => { %>
            <tr class="ticket-row" onclick="window.location='/tickets/<%= t.id %>'">
              <td><span class="ticket-id"><%= t.id %></span></td>
              <td class="ticket-title-cell">
                <span class="ticket-title-text"><%= t.titulo %></span>
                <% if (t.etiquetas && t.etiquetas.length) { %>
                <div class="ticket-tags">
                  <% t.etiquetas.slice(0,3).forEach(etq => { %>
                  <span class="tag">#<%= etq %></span>
                  <% }) %>
                </div>
                <% } %>
              </td>
              <td>
                <span class="badge <%= estadoMeta[t.estado] ? estadoMeta[t.estado].badge : 'badge-slate' %>">
                  <%= t.estado %>
                </span>
              </td>
              <td>
                <span class="badge badge-prioridad-<%= t.prioridad.toLowerCase() %>">
                  <%= t.prioridad %>
                </span>
              </td>
              <td style="color:var(--text-muted); font-size:11px; max-width:140px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                <%= t.tipo %>
              </td>
              <td style="font-size:11px; color:var(--text-secondary);">
                <%= t.solicitanteNombre %>
              </td>
              <td style="color:var(--text-muted); font-size:11px; white-space:nowrap;">
                <%= new Date(t.fechaActualizacion).toLocaleDateString('es-MX', {day:'2-digit', month:'short', year:'numeric'}) %>
              </td>
              <td onclick="event.stopPropagation();">
                <a href="/tickets/<%= t.id %>" class="btn btn-ghost btn-sm">Ver →</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <div style="padding:8px 12px; border-top:0.5px solid var(--border); font-size:11px; color:var(--text-muted);">
          Mostrando <strong style="color:var(--text-secondary);"><%= tickets.length %></strong> ticket<%= tickets.length !== 1 ? 's' : '' %>
        </div>
        <% } %>
      </div>

    </div>

    <%- include('partials/footer') %>
  </div>
</div>
