<%- include('../partials/head') %>

<div class="app-wrapper">
  <%- include('../partials/sidebar', { user, roles }) %>

  <div class="main-content">

    <!-- TOPBAR -->
    <header class="topbar">
      <button id="sidebar-toggle" class="btn btn-ghost btn-icon" aria-label="Abrir menú">☰</button>
      <div class="topbar-title">
        <% if (proyecto) { %>
          Editar Proyecto: <span style="color:var(--accent);"><%= proyecto.nombre %></span>
        <% } else { %>
          Nuevo Proyecto
        <% } %>
      </div>
      <div class="topbar-actions">
        <a href="/admin/proyectos" class="btn btn-ghost btn-sm">← Volver a Proyectos</a>
        <span class="badge badge-purple" style="font-size:0.72rem;"><%= user.rol %></span>
      </div>
    </header>

    <div class="page-container">

      <div style="max-width:720px; margin: 0 auto;">
        <div class="card">
          <div class="card-header" style="margin-bottom:1.5rem;">
            <div>
              <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:0.25rem;">
                <% if (proyecto) { %>Editar Proyecto<% } else { %>Crear Nuevo Proyecto<% } %>
              </h2>
              <p style="font-size:0.82rem; color:var(--text-muted); margin:0;">
                <% if (proyecto) { %>Modifica los datos del proyecto.<% } else { %>Completa el formulario para crear un nuevo proyecto en el sistema.<% } %>
              </p>
            </div>
          </div>

          <form id="form-proyecto" onsubmit="guardarProyecto(event)">

            <!-- Nombre -->
            <div class="form-group">
              <label class="form-label">Nombre del Proyecto *</label>
              <input
                type="text"
                name="nombre"
                class="form-control"
                required
                placeholder="Ej: Sistema de Gestión de Inventario"
                value="<%= proyecto ? proyecto.nombre : '' %>"
              >
              <span class="form-hint">Nombre descriptivo y único para identificar el proyecto.</span>
            </div>

            <!-- Descripción -->
            <div class="form-group">
              <label class="form-label">Descripción</label>
              <textarea
                name="descripcion"
                class="form-control"
                rows="4"
                placeholder="Descripción detallada del proyecto, objetivos, alcance..."
              ><%= proyecto ? proyecto.descripcion : '' %></textarea>
            </div>

            <!-- Estado + Metodología -->
            <div class="grid-2" style="gap:0.75rem;">
              <div class="form-group">
                <label class="form-label">Estado *</label>
                <select name="estado" class="form-control" required>
                  <% estadosProyecto.forEach(e => { %>
                  <option value="<%= e %>" <%= proyecto && proyecto.estado === e ? 'selected' : '' %>><%= e %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Metodología</label>
                <select name="id_metodologia" class="form-control">
                  <option value="">— Sin metodología —</option>
                  <% metodologias.forEach(m => { %>
                  <option value="<%= m.id_metodologia %>"
                    <%= proyecto && String(proyecto.id_metodologia) === String(m.id_metodologia) ? 'selected' : '' %>
                  ><%= m.nombre %></option>
                  <% }) %>
                </select>
                <span class="form-hint">Marco de trabajo que seguirá el proyecto.</span>
              </div>
            </div>

            <!-- Fechas -->
            <div class="grid-2" style="gap:0.75rem;">
              <div class="form-group">
                <label class="form-label">Fecha de Inicio</label>
                <input
                  type="date"
                  name="fecha_inicio"
                  class="form-control"
                  onclick="this.showPicker()"
                  onfocus="this.showPicker()"
                  value="<%= proyecto && proyecto.fecha_inicio ? new Date(proyecto.fecha_inicio).toISOString().substring(0,10) : '' %>"
                >
              </div>
              <div class="form-group">
                <label class="form-label">Fecha de Fin Estimada</label>
                <input
                  type="date"
                  name="fecha_fin"
                  class="form-control"
                  onclick="this.showPicker()"
                  onfocus="this.showPicker()"
                  value="<%= proyecto && proyecto.fecha_fin ? new Date(proyecto.fecha_fin).toISOString().substring(0,10) : '' %>"
                >
              </div>
            </div>

            <!-- GitHub Configuration -->
            <div class="form-group" style="margin-top:1rem;">
              <label class="form-label">Repositorio de GitHub (opcional)</label>
              <input
                type="text"
                name="github_repo"
                id="github_repo"
                class="form-control"
                placeholder="Ej: owner/repo"
                value="<%= proyecto && proyecto.github_repo ? proyecto.github_repo : '' %>"
              >
              <span class="form-hint">Formato: <code>propietario/repositorio</code>. Si se asocia, las versiones de los ECS se subirán aquí.</span>
            </div>

            <% if (!proyecto) { %>
            <div class="form-group" id="auto-create-repo-group" style="display: none; margin-top: -0.5rem; margin-bottom: 1.25rem;">
              <label class="form-label" style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; font-size:0.85rem;">
                <input type="checkbox" name="auto_crear_repo" id="auto_crear_repo" value="true" onchange="toggleGithubRepoInput()">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--blue); flex-shrink:0;"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
                <span>Auto-crear un nuevo repositorio en mi GitHub</span>
              </label>
              <span class="form-hint">Crea automáticamente un repositorio con el nombre del proyecto en tu cuenta de GitHub.</span>
            </div>
            <% } %>

            <!-- Divider -->
            <div class="divider" style="margin: 1.25rem 0;"></div>

            <!-- Mensaje de error -->
            <div id="form-error" style="display:none;" class="alert alert-error"></div>

            <!-- Acciones -->
            <div style="display:flex; gap:0.75rem; justify-content:flex-end; align-items:center;">
              <a href="/admin/proyectos" class="btn btn-ghost">Cancelar</a>
              <button type="submit" class="btn btn-primary" id="btn-submit" style="display:inline-flex; align-items:center; gap:0.5rem;">
                <% if (proyecto) { %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                  Guardar Cambios
                <% } else { %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  Crear Proyecto
                <% } %>
              </button>
            </div>

          </form>
        </div>

        <!-- Info adicional si editando -->
        <% if (proyecto) { %>
          <div class="card-header" style="display:flex; align-items:center; gap:0.5rem; margin-bottom:1rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            <span class="card-title" style="margin:0;">Acciones del Proyecto</span>
          </div>
          <div style="display:flex; gap:0.65rem; flex-wrap:wrap;">
            <a href="/admin/proyectos/<%= proyecto.id_proyecto %>/config" class="btn btn-secondary btn-sm" style="display:inline-flex; align-items:center; gap:0.4rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              Configuración Completa
            </a>
            <a href="/admin/proyectos/<%= proyecto.id_proyecto %>/config#tab-equipo" class="btn btn-ghost btn-sm" style="display:inline-flex; align-items:center; gap:0.4rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              Gestionar Equipo
            </a>
            <a href="/admin/proyectos/<%= proyecto.id_proyecto %>/config#tab-cronograma" class="btn btn-ghost btn-sm" style="display:inline-flex; align-items:center; gap:0.4rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Ver Cronograma
            </a>
          </div>
        <% } %>
      </div>

    </div><!-- /page-container -->

    <%- include('../partials/footer') %>
  </div><!-- /main-content -->
</div><!-- /app-wrapper -->

<script>
  async function guardarProyecto(e) {
    e.preventDefault();
    const btn = document.getElementById('btn-submit');
    const errEl = document.getElementById('form-error');
    const originalText = btn.textContent;
    btn.textContent = 'Guardando...'; btn.disabled = true;
    errEl.style.display = 'none';

    const fd = new FormData(e.target);
    const body = Object.fromEntries(fd.entries());
    // Limpiar campos vacíos
    if (!body.id_metodologia) delete body.id_metodologia;
    if (!body.fecha_inicio) delete body.fecha_inicio;
    if (!body.fecha_fin) delete body.fecha_fin;

    const isEdit = <%= proyecto ? 'true' : 'false' %>;
    const id = <%= proyecto ? proyecto.id_proyecto : 'null' %>;
    const url = isEdit ? `/api/admin/proyectos/${id}` : '/api/admin/proyectos';
    const method = isEdit ? 'PUT' : 'POST';

    try {
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Error al guardar proyecto');

      // Redirigir a config si nuevo, o a lista si editando
      if (isEdit) {
        window.location.href = `/admin/proyectos/${id}/config`;
      } else {
        window.location.href = `/admin/proyectos/${data.id_proyecto || data.id}/config`;
      }
    } catch(err) {
      errEl.textContent = err.message; errEl.style.display = 'flex';
      btn.textContent = originalText; btn.disabled = false;
    }
  }

  // Validar que fecha_fin sea posterior a fecha_inicio
  const fechaInicio = document.querySelector('[name=fecha_inicio]');
  const fechaFin = document.querySelector('[name=fecha_fin]');
  if (fechaFin) {
    fechaFin.addEventListener('change', () => {
      if (fechaInicio.value && fechaFin.value && fechaFin.value < fechaInicio.value) {
        alert('La fecha de fin no puede ser anterior a la fecha de inicio.');
        fechaFin.value = '';
      }
    });
  }

  // Verificar conexión con GitHub para mostrar opción de auto-crear
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const res = await fetch('/api/usuario/github-status');
      const data = await res.json();
      if (data.success && data.conectado) {
        const autoCreateGroup = document.getElementById('auto-create-repo-group');
        if (autoCreateGroup) {
          autoCreateGroup.style.display = 'block';
        }
      }
    } catch (e) {
      console.error('Error al verificar estado de GitHub:', e);
    }
  });

  function toggleGithubRepoInput() {
    const chk = document.getElementById('auto_crear_repo');
    const input = document.getElementById('github_repo');
    if (chk && chk.checked) {
      input.disabled = true;
      input.value = '';
      input.placeholder = 'Se creará automáticamente al enviar...';
    } else {
      input.disabled = false;
      input.placeholder = 'Ej: owner/repo';
    }
  }
</script>
