<script src="https://cdnjs.cloudflare.com/ajax/libs/jsdiff/5.2.0/diff.min.js"></script>

<script>
  const PROYECTO_ID = <%= proyecto.id_proyecto %>;
  const PROYECTO_GITHUB_REPO = '<%= proyecto.github_repo || "" %>';
  const ACTIVIDADES_CRONOGRAMA = <%- JSON.stringify(cronograma) %>;
  const TODOS_USUARIOS = <%- JSON.stringify(todosUsuarios) %>;
  const PROYECTO_FECHA_INICIO = '<%= proyecto.fecha_inicio ? new Date(proyecto.fecha_inicio).toISOString().substring(0,10) : "" %>';
  const PROYECTO_FECHA_FIN = '<%= proyecto.fecha_fin ? new Date(proyecto.fecha_fin).toISOString().substring(0,10) : "" %>';

  // ─── Cargar Equipo/Clientes Predeterminados del Sistema ──────────────────────
  async function agregarEquipoPredeterminado() {
    const mapeoPredeterminado = {
      'sergio@upt.pe': 'Gestor de Configuración',
      'diego@upt.pe': 'Líder Técnico',
      'gregory@upt.pe': 'Desarrollador Asignado',
      'cesar@upt.pe': 'Equipo QA / Tester',
      'director@upt.pe': 'Director',
      'ccb@upt.pe': 'Comité de Control (CCB)'
    };

    const usuariosParaAgregar = [];

    // Filtrar los usuarios globales que coincidan con los correos del equipo de demo
    TODOS_USUARIOS.forEach(u => {
      const rolProyecto = mapeoPredeterminado[u.correo];
      if (rolProyecto) {
        usuariosParaAgregar.push({
          id_usuario: u.id,
          rol_en_proyecto: rolProyecto,
          nombre: u.nombre
        });
      }
    });

    if (usuariosParaAgregar.length === 0) {
      alert('No se encontraron los usuarios de demostración predefinidos en la base de datos.');
      return;
    }

    if (!confirm(`¿Deseas agregar automáticamente a los ${usuariosParaAgregar.length} miembros predefinidos con sus roles en el proyecto?`)) {
      return;
    }

    let agregados = 0;
    let errores = [];

    for (const usr of usuariosParaAgregar) {
      try {
        const res = await fetch(`/api/admin/proyectos/${PROYECTO_ID}/equipo`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({
            id_usuario: usr.id_usuario,
            rol_en_proyecto: usr.rol_en_proyecto
          })
        });
        const data = await res.json();
        if (res.ok) {
          agregados++;
        } else {
          // Ignorar duplicados
          if (data.error && (data.error.includes('duplicate') || data.error.includes('ya existe') || data.error.includes('repetido') || data.error.includes('Miembro ya registrado'))) {
            // Ya registrado
          } else {
            errores.push(`${usr.nombre}: ${data.error || 'Error'}`);
          }
        }
      } catch (err) {
        errores.push(`${usr.nombre}: ${err.message}`);
      }
    }

    if (errores.length > 0) {
      alert(`Se agregaron ${agregados} miembros. Hubo algunos detalles:\n` + errores.join('\n'));
    } else {
      alert(`¡Se agregaron con éxito ${agregados} miembros al equipo del proyecto!`);
    }
    location.reload();
  }

  async function agregarClientesPredeterminados() {
    const correosPredeterminados = ['docente@upt.pe'];
    const usuariosParaAgregar = [];

    TODOS_USUARIOS.forEach(u => {
      if (correosPredeterminados.includes(u.correo)) {
        usuariosParaAgregar.push({
          id_usuario: u.id,
          nombre: u.nombre
        });
      }
    });

    if (usuariosParaAgregar.length === 0) {
      alert('No se encontró el cliente predefinido (docente@upt.pe) en la base de datos.');
      return;
    }

    if (!confirm(`¿Deseas agregar automáticamente a los clientes predefinidos (docente@upt.pe)?`)) {
      return;
    }

    let agregados = 0;
    let errores = [];

    for (const usr of usuariosParaAgregar) {
      try {
        const res = await fetch(`/api/admin/proyectos/${PROYECTO_ID}/clientes`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({
            id_usuario: usr.id_usuario
          })
        });
        const data = await res.json();
        if (res.ok) {
          agregados++;
        } else {
          if (data.error && (data.error.includes('duplicate') || data.error.includes('ya existe') || data.error.includes('registrado'))) {
            // Ya registrado
          } else {
            errores.push(`${usr.nombre}: ${data.error || 'Error'}`);
          }
        }
      } catch (err) {
        errores.push(`${usr.nombre}: ${err.message}`);
      }
    }

    if (errores.length > 0) {
      alert(`Se agregaron ${agregados} clientes. Detalles:\n` + errores.join('\n'));
    } else {
      alert(`¡Se agregaron con éxito ${agregados} clientes al proyecto!`);
    }
    location.reload();
  }

  let cronYear = new Date().getFullYear();
  let cronMonth = new Date().getMonth();

  // ─── Tabs ───────────────────────────────────────────────────────────────────
  function switchTab(panelId, btn) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById(panelId).classList.add('active');
    btn.classList.add('active');
    
    // Guardar pestaña activa
    localStorage.setItem('activeTab_' + PROYECTO_ID, panelId);

    // Si entramos a la pestaña del cronograma, inicializar el calendario si no está inicializado
    if (panelId === 'tab-cronograma') {
      const savedView = localStorage.getItem('cronogramaView_' + PROYECTO_ID) || 'calendario';
      switchCronogramaView(savedView);
    }
  }

  // Restaurar pestaña activa al cargar la página
  document.addEventListener('DOMContentLoaded', () => {
    initCronogramaCalendar();
    const savedView = localStorage.getItem('cronogramaView_' + PROYECTO_ID) || 'calendario';
    switchCronogramaView(savedView);

    // 1. Verificar si hay pestaña especificada en la URL (ej: ?tab=tickets)
    const urlParams = new URLSearchParams(window.location.search);
    const urlTab = urlParams.get('tab');
    if (urlTab) {
      const btn = document.getElementById('btn-tab-' + urlTab);
      if (btn) {
        switchTab('tab-' + urlTab, btn);
        return;
      }
    }

    // 2. Si no, restaurar desde localStorage
    const activeTab = localStorage.getItem('activeTab_' + PROYECTO_ID);
    if (activeTab) {
      const btn = document.getElementById('btn-' + activeTab);
      if (btn) {
        switchTab(activeTab, btn);
      }
    }
  });

  // ─── Calendario Mensual del Cronograma ──────────────────────────────────────
  function switchCronogramaView(view) {
    const calendarView = document.getElementById('cview-calendario');
    const ganttView = document.getElementById('cview-gantt');
    const tablaView = document.getElementById('cview-tabla');
    
    if (!calendarView || !ganttView || !tablaView) return;

    // Ocultar todas
    calendarView.style.display = 'none';
    ganttView.style.display = 'none';
    tablaView.style.display = 'none';
    
    // Quitar active de botones
    const btnCal = document.getElementById('subbtn-calendario');
    const btnGantt = document.getElementById('subbtn-gantt');
    const btnTabla = document.getElementById('subbtn-tabla');

    if (btnCal) { btnCal.classList.remove('active'); btnCal.style.color = 'var(--text-muted)'; }
    if (btnGantt) { btnGantt.classList.remove('active'); btnGantt.style.color = 'var(--text-muted)'; }
    if (btnTabla) { btnTabla.classList.remove('active'); btnTabla.style.color = 'var(--text-muted)'; }

    // Mostrar la seleccionada
    if (view === 'calendario') {
      calendarView.style.display = 'block';
      if (btnCal) { btnCal.classList.add('active'); btnCal.style.color = 'var(--accent)'; }
      renderCronogramaCalendar();
    } else if (view === 'gantt') {
      ganttView.style.display = 'block';
      if (btnGantt) { btnGantt.classList.add('active'); btnGantt.style.color = 'var(--accent)'; }
    } else {
      tablaView.style.display = 'block';
      if (btnTabla) { btnTabla.classList.add('active'); btnTabla.style.color = 'var(--accent)'; }
    }
    localStorage.setItem('cronogramaView_' + PROYECTO_ID, view);
  }

  function initCronogramaCalendar() {
    const minD = PROYECTO_FECHA_INICIO;
    if (minD) {
      const parts = minD.split('-');
      cronYear = parseInt(parts[0]);
      cronMonth = parseInt(parts[1]) - 1;
    } else if (ACTIVIDADES_CRONOGRAMA.length > 0) {
      const parts = ACTIVIDADES_CRONOGRAMA[0].fecha_inicio.split('-');
      cronYear = parseInt(parts[0]);
      cronMonth = parseInt(parts[1]) - 1;
    }
  }

  function renderCronogramaCalendar() {
    const MESES_NOMBRES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio',
                           'Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    
    const tituloEl = document.getElementById('cron-cal-titulo');
    if (tituloEl) tituloEl.textContent = `${MESES_NOMBRES[cronMonth]} ${cronYear}`;
    
    const grid = document.getElementById('cron-cal-grid');
    if (!grid) return;
    grid.innerHTML = '';
    
    // Primer día del mes
    const primero = new Date(cronYear, cronMonth, 1);
    // Lunes = 0, ..., Domingo = 6
    let offset = primero.getDay() - 1;
    if (offset < 0) offset = 6;
    
    // Total de días del mes
    const totalDias = new Date(cronYear, cronMonth + 1, 0).getDate();
    // Total de días del mes anterior
    const totalDiasAnt = new Date(cronYear, cronMonth, 0).getDate();
    
    // Celdas mes anterior
    for (let i = offset - 1; i >= 0; i--) {
      const d = totalDiasAnt - i;
      grid.appendChild(crearCeldaCalendario(cronYear, cronMonth - 1, d, true));
    }
    
    // Celdas mes actual
    for (let d = 1; d <= totalDias; d++) {
      grid.appendChild(crearCeldaCalendario(cronYear, cronMonth, d, false));
    }
    
    // Celdas mes siguiente para completar la cuadrícula de 7 columnas
    const totalCeldasActuales = offset + totalDias;
    const celdasFaltantes = (7 - (totalCeldasActuales % 7)) % 7;
    for (let d = 1; d <= celdasFaltantes; d++) {
      grid.appendChild(crearCeldaCalendario(cronYear, cronMonth + 1, d, true));
    }
  }

  // Helper para parsear fechas de forma segura sin desvíos de zona horaria (UTC/Local)
  function parseLocalDate(dateInput) {
    if (!dateInput) return null;
    const str = (typeof dateInput === 'string') ? dateInput : new Date(dateInput).toISOString();
    const datePart = str.substring(0, 10); // "YYYY-MM-DD"
    const parts = datePart.split('-');
    return new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
  }

  function crearCeldaCalendario(año, mes, dia, esOtroMes) {
    const cell = document.createElement('div');
    cell.className = 'calendar-cell' + (esOtroMes ? ' other-month' : '');
    
    const fecha = new Date(año, mes, dia);
    fecha.setHours(0,0,0,0);
    
    // Obtener formato YYYY-MM-DD en hora local sin desvíos UTC
    const yyyy = fecha.getFullYear();
    const mm = String(fecha.getMonth() + 1).padStart(2, '0');
    const dd = String(fecha.getDate()).padStart(2, '0');
    const fechaStr = `${yyyy}-${mm}-${dd}`;
    
    const hoy = new Date();
    hoy.setHours(0,0,0,0);
    if (fecha.getTime() === hoy.getTime()) {
      cell.classList.add('today-cell');
    }
    
    const num = document.createElement('div');
    num.className = 'calendar-day-num';
    num.textContent = dia;
    cell.appendChild(num);
    
    if (esOtroMes) {
      cell.style.cursor = 'not-allowed';
    } else {
      cell.onclick = () => {
        abrirNuevaActividadConFecha(fechaStr);
      };
    }
    
    // Buscar actividades activas en esta fecha
    ACTIVIDADES_CRONOGRAMA.forEach(a => {
      const ini = parseLocalDate(a.fecha_inicio);
      const fin = parseLocalDate(a.fecha_fin);
      if (!ini || !fin) return;
      
      if (fecha >= ini && fecha <= fin) {
        const ev = document.createElement('div');
        let estClass = 'event-pendiente';
        if (a.estado === 'Completado') estClass = 'event-completado';
        else if (a.estado === 'En Progreso') estClass = 'event-progreso';
        else if (a.estado === 'Bloqueado') estClass = 'event-bloqueado';
        
        ev.className = `calendar-event ${estClass}`;
        ev.textContent = `[${parseFloat(a.porcentaje_avance).toFixed(0)}%] ${a.nombre}`;
        ev.title = `${a.nombre} (${a.estado} - ${parseFloat(a.porcentaje_avance).toFixed(0)}%)\nResponsable: ${a.asignado_nombre || 'Sin asignar'}`;
        
        ev.onclick = (e) => {
          e.stopPropagation();
          editarActividad(a);
        };
        
        cell.appendChild(ev);
      }
    });
    
    return cell;
  }

  function navigateCronogramaCalendar(dir) {
    cronMonth += dir;
    if (cronMonth < 0)  { cronMonth = 11; cronYear--; }
    if (cronMonth > 11) { cronMonth = 0;  cronYear++; }
    renderCronogramaCalendar();
  }

  function goTodayCronogramaCalendar() {
    const hoy = new Date();
    cronYear = hoy.getFullYear();
    cronMonth = hoy.getMonth();
    renderCronogramaCalendar();
  }

  function abrirNuevaActividadConFecha(fechaStr) {
    // Verificar límites del proyecto
    if (PROYECTO_FECHA_INICIO && fechaStr < PROYECTO_FECHA_INICIO) {
      alert(`La fecha seleccionada (${fechaStr}) es anterior a la fecha de inicio del proyecto (${PROYECTO_FECHA_INICIO}).`);
      return;
    }
    if (PROYECTO_FECHA_FIN && fechaStr > PROYECTO_FECHA_FIN) {
      alert(`La fecha seleccionada (${fechaStr}) es posterior a la fecha de fin del proyecto (${PROYECTO_FECHA_FIN}).`);
      return;
    }
    
    abrirNuevaActividad();
    document.getElementById('act-fecha-inicio').value = fechaStr;
    document.getElementById('act-fecha-fin').value = fechaStr;
  }

