  async function guardarActividad(e) {
    e.preventDefault();
    const btn = document.getElementById('btn-guardar-act');
    const errEl = document.getElementById('error-actividad');
    btn.textContent = 'Guardando...'; btn.disabled = true; errEl.style.display = 'none';
    const fd = new FormData(e.target);
    const body = Object.fromEntries(fd.entries());
    body.es_reportable = document.getElementById('act-reportable').checked ? 1 : 0;
    // Limpiar campos vacíos opcionales
    if (!body.id_fase) delete body.id_fase;
    if (!body.id_usuario) delete body.id_usuario;
    if (!body.id_entregable) delete body.id_entregable;
    
    // Validación de fechas en cliente
    if (body.fecha_inicio && body.fecha_fin && body.fecha_inicio > body.fecha_fin) {
      errEl.textContent = 'La fecha de inicio no puede ser posterior a la fecha de fin.';
      errEl.style.display = 'flex';
      btn.textContent = 'Guardar Actividad'; btn.disabled = false;
      return;
    }
    if (PROYECTO_FECHA_INICIO && body.fecha_inicio < PROYECTO_FECHA_INICIO) {
      errEl.textContent = `La fecha de inicio (${body.fecha_inicio}) es anterior a la fecha de inicio del proyecto (${PROYECTO_FECHA_INICIO}).`;
      errEl.style.display = 'flex';
      btn.textContent = 'Guardar Actividad'; btn.disabled = false;
      return;
    }
    if (PROYECTO_FECHA_FIN && body.fecha_fin > PROYECTO_FECHA_FIN) {
      errEl.textContent = `La fecha de fin (${body.fecha_fin}) es posterior a la fecha de fin del proyecto (${PROYECTO_FECHA_FIN}).`;
      errEl.style.display = 'flex';
      btn.textContent = 'Guardar Actividad'; btn.disabled = false;
      return;
    }

    const id = body.id_actividad;
    const url = id ? `/api/admin/proyectos/${PROYECTO_ID}/cronograma/${id}` : `/api/admin/proyectos/${PROYECTO_ID}/cronograma`;
    const method = id ? 'PUT' : 'POST';
    try {
      const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Error al guardar');
      location.reload();
    } catch(err) {
      errEl.textContent = err.message; errEl.style.display = 'flex';
      btn.textContent = 'Guardar Actividad'; btn.disabled = false;
    }
  }
