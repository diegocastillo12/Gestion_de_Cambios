<%- include('partials/head') %>

<style>
.reporte-hero {
  background: var(--surface-2);
  border: 0.5px solid var(--border);
  border-left: 2px solid var(--border-accent);
  border-radius: var(--radius); padding: 20px 24px; margin-bottom: 16px;
  display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
}
.reporte-hero h1 { font-size: 15px; font-weight: 500; color: var(--text-primary); }
.reporte-hero p  { color: var(--text-muted); font-size: 12px; margin-top: 4px; }

.informe-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;
}
@media (max-width: 900px) { .informe-grid { grid-template-columns: 1fr; } }

.ranking-table { width: 100%; border-collapse: collapse; }
.ranking-table th, .ranking-table td {
  padding: 8px 12px; border-bottom: 0.5px solid var(--border);
  font-size: 12px; text-align: left;
}
.ranking-table th { color: var(--text-muted); font-weight: 500; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; }
.rank-pos { text-align: center; font-weight: 600; font-size: 13px; color: var(--text-accent); }

.informe-row {
  display: flex; align-items: center; gap: 12px;
  padding: 8px 0; border-bottom: 0.5px solid var(--border);
}
.informe-nombre { flex: 1; font-weight: 500; font-size: 12px; }
.informe-meta   { font-size: 11px; color: var(--text-muted); }
.informe-pct    { font-weight: 600; color: var(--text-accent); width: 40px; text-align: right; font-size: 12px; }

.log-entry {
  display: flex; gap: 12px; padding: 10px 0;
  border-bottom: 0.5px solid var(--border); align-items: flex-start;
}
.log-avatar {
  width: 34px; height: 34px; border-radius: 50%;
  background: var(--bg-accent);
  border: 0.5px solid var(--border-accent);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 600; color: var(--text-accent); flex-shrink: 0;
}
.log-content { flex: 1; }
.log-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px; }
.log-nombre { font-weight: 500; font-size: 12px; color: var(--text-primary); }
.log-fecha  { font-size: 11px; color: var(--text-muted); }
.log-actividad { font-size: 11px; color: var(--text-muted); }
.log-pct { font-weight: 600; font-size: 13px; color: var(--text-accent); flex-shrink: 0; }

.progress-mini-outer { background: var(--surface-1); border-radius: 99px; height: 5px; overflow: hidden; border: 0.5px solid var(--border); }
.progress-mini-inner { height: 100%; border-radius: 99px; background: var(--text-accent); }

.promedio-big {
  font-size: 36px; font-weight: 600;
  color: var(--text-accent);
  line-height: 1;
}
</style>

<div class="app-wrapper">
  <%- include('partials/sidebar') %>

  <main class="main-content">

    <div class="reporte-hero">
      <div>
        <h1>Reportes de Avance</h1>
        <p>Proyecto: <strong style="color:var(--text-primary);"><%= proyecto.nombre %></strong></p>
      </div>
      <div style="text-align:right;">
        <div class="promedio-big"><%= promedio %>%</div>
        <div style="color:var(--text-muted);font-size:11px;margin-top:4px;">Avance promedio del proyecto</div>
      </div>
    </div>

    <div class="informe-grid">

      <!-- Ranking -->
      <div class="card">
        <h2 style="font-size:13px;font-weight:500;margin-bottom:16px;">Ranking del Equipo</h2>
        <% if(ranking && ranking.length > 0) { %>
        <% const medallas = ['1', '2', '3']; %>
        <table class="ranking-table">
          <thead><tr><th>#</th><th>Miembro</th><th>Rol</th><th>Reportes</th><th>Promedio</th></tr></thead>
          <tbody>
          <% ranking.forEach((m, i) => { %>
          <tr>
            <td class="rank-pos">#<%= medallas[i] || (i+1) %></td>
            <td>
              <div style="font-weight:600;"><%= m.nombre %></div>
              <% if(m.ultimo_reporte) { %>
              <div style="font-size:0.72rem;color:var(--text-muted);">
                Último: <%= new Date(m.ultimo_reporte).toLocaleDateString('es-PE') %>
              </div>
              <% } %>
            </td>
            <td style="color:var(--text-muted);font-size:0.82rem;"><%= m.rol %></td>
            <td style="text-align:center;"><%= m.total_reportes %></td>
            <td>
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <div class="progress-mini-outer" style="min-width:60px;flex:1;">
                  <div class="progress-mini-inner" style="width:<%= Math.min(100,m.promedio_avance||0) %>%;"></div>
                </div>
                <span style="font-weight:700;color:var(--accent);font-size:0.85rem;">
                  <%= parseFloat(m.promedio_avance||0).toFixed(1) %>%
                </span>
              </div>
            </td>
          </tr>
          <% }); %>
          </tbody>
        </table>
        <% } else { %>
        <div style="text-align:center;padding:2rem;color:var(--text-muted);">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 10px;display:block;opacity:0.4;"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
          <p style="font-size:12px;">Sin reportes registrados.</p>
        </div>
        <% } %>
      </div>

      <!-- Informe por actividad -->
      <div class="card">
        <h2 style="font-size:13px;font-weight:500;margin-bottom:16px;">Informe por Actividad</h2>
        <% if(informe && informe.length > 0) { %>
        <% informe.forEach(act => { %>
        <div class="informe-row">
          <div style="flex:1;">
            <div class="informe-nombre"><%= act.actividad %></div>
            <% if(act.reportado_por) { %>
            <div class="informe-meta">Último: <%= act.reportado_por %> · <%= act.fecha_ultimo_reporte ? new Date(act.fecha_ultimo_reporte).toLocaleDateString('es-PE') : '' %></div>
            <% } else { %><div class="informe-meta">Sin reportes</div><% } %>
            <% if(act.ultimo_comentario) { %>
            <div class="informe-meta" style="font-style:italic;">"<%= act.ultimo_comentario %>"</div>
            <% } %>
          </div>
          <div style="min-width:120px;text-align:right;">
            <div class="informe-pct"><%= parseFloat(act.porcentaje_avance||0).toFixed(0) %>%</div>
            <div class="progress-mini-outer" style="width:100%;margin-top:0.3rem;">
              <div class="progress-mini-inner" style="width:<%= act.porcentaje_avance||0 %>%;height:8px;"></div>
            </div>
          </div>
        </div>
        <% }); %>
        <% } else { %>
        <div style="text-align:center;padding:2rem;color:var(--text-muted);">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 10px;display:block;opacity:0.4;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p style="font-size:12px;">Sin actividades.</p>
        </div>
        <% } %>
      </div>

    </div>

    <!-- Log de reportes -->
    <div class="card">
      <h2 style="font-size:13px;font-weight:500;margin-bottom:16px;">Historial de Reportes</h2>
      <% if(reportes && reportes.length > 0) { %>
      <% reportes.forEach(r => { %>
      <div class="log-entry">
        <div class="log-avatar"><%= r.reportado_por.slice(0,2).toUpperCase() %></div>
        <div class="log-content">
          <div class="log-header">
            <span class="log-nombre"><%= r.reportado_por %></span>
            <span class="log-fecha">
              <%= new Date(r.fecha_reporte).toLocaleDateString('es-PE', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
            </span>
          </div>
          <div class="log-actividad"><%= r.actividad_nombre %></div>
          <% if(r.comentario) { %><div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.25rem;">"<%= r.comentario %>"</div><% } %>
        </div>
        <div class="log-pct"><%= r.porcentaje %>%</div>
      </div>
      <% }); %>
      <% } else { %>
      <div style="text-align:center;padding:3rem;color:var(--text-muted);">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 12px;display:block;opacity:0.4;"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        <p style="font-size:12px;">No hay reportes de avance registrados.</p>
      </div>
      <% } %>
    </div>

    <div style="margin-top:1rem;">
      <a href="/proyectos/<%= proyecto.id_proyecto %>" class="btn btn-ghost">← Volver al proyecto</a>
    </div>

  </main>
</div>

<%- include('partials/footer') %>
